# Configuration for Static Webpage
# Note: These values should be added directly to index.html in the CONFIG object

# Google OAuth Configuration (for Web Application)
# GOOGLE_CLIENT_ID=your-google-client-id-here

# Google API Key (for accessing Google Sheets API)
# GOOGLE_API_KEY=your-google-api-key-here

# Google Sheets Configuration
# SPREADSHEET_ID=your-google-spreadsheet-id-here
